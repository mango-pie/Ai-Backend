# 复制到服务器 /etc/ai-backend.env 并填入真实值
# chmod 600 /etc/ai-backend.env

# ---- 服务器（IP 访问模式）----
SERVER_IP=121.43.177.236

# ---- 数据库 ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=aiscene
DB_PASSWORD=change-me

# ---- Redis（2GB 服务器可注释掉，后端会自动降级为内存 Session）----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- AI 服务（必填）----
DASHSCOPE_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=sk-your-dashscope-key
CHAT_IMAGE_CAPTION_API_KEY=sk-your-dashscope-key

CODEGEN_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CODEGEN_API_KEY=sk-your-codegen-key
CODEGEN_MODEL_NAME=deepseek-v3

# ---- AstrBot 聊天（Ask 模式）----
ASTRBOT_BASE_URL=http://121.40.253.15:6185
ASTRBOT_API_KEY=abk-your-astrbot-key

# ---- 站点 URL（IP 模式）----
APP_DEPLOY_HOST=http://121.43.177.236
UPLOAD_BASE_URL=http://121.43.177.236/api

# ---- TTS（2GB 服务器建议关闭）----
GPT_SOVITS_SEED_ENABLED=false

# ---- 可选：强制 Redis 模式 auto | on | off ----
# APP_REDIS_MODE=auto
