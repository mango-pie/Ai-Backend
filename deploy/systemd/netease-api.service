[Unit]
Description=Netease Cloud Music API (api-enhanced)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/netease-api
Environment=PORT=3000
Environment=NODE_OPTIONS=--max-old-space-size=128
ExecStart=/usr/bin/node app.js
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=netease-api

[Install]
WantedBy=multi-user.target
